{
  "name": "smartshala-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run prisma:generate:all && tsc",
    "start": "node scripts/render-start.mjs",
    "start:server": "node dist/server.js",
    "render:start": "node scripts/render-start.mjs",
    "prisma:generate": "prisma generate",
    "prisma:generate:master": "prisma generate --schema prisma/master/schema.prisma",
    "prisma:generate:all": "npm run prisma:generate && npm run prisma:generate:master",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:master": "prisma migrate deploy --schema prisma/master/schema.prisma",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "tenant:register-existing": "node scripts/register-existing-school.mjs",
    "tenant:migrate-all": "node scripts/migrate-tenants.mjs",
    "lint": "tsc --noEmit",
    "test:grading": "tsx tests/grading.test.ts",
    "test:attendance": "tsx tests/studentAttendance.test.ts",
    "test:marks-term": "tsx tests/marksExamTerm.test.ts",
    "test:fee-adjustment": "tsx tests/feeAdjustmentSchema.test.ts",
    "test:rollover": "tsx tests/academicYearRollover.test.ts",
    "backup:master": "node scripts/backup-master-db.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.1059.0",
    "@aws-sdk/s3-request-presigner": "^3.1059.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openai": "^6.42.0",
    "pdfkit": "^0.18.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.17.6",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
