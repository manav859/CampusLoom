# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# PostgreSQL
# Use Neon's pooled endpoint for application traffic.
DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.c-7.us-east-1.aws.neon.tech/smartshala?sslmode=require&channel_binding=require"
# Use Neon's direct endpoint for Prisma migrations and schema commands.
DIRECT_URL="postgresql://USER:PASSWORD@ep-example.c-7.us-east-1.aws.neon.tech/smartshala?sslmode=require"

# Multi-tenant master database and Neon onboarding.
MASTER_DATABASE_URL="postgresql://USER:PASSWORD@ep-example.c-7.us-east-1.aws.neon.tech/master_db?sslmode=require"
NEON_API_KEY="replace-with-neon-api-key"
NEON_PROJECT_ID="replace-with-neon-project-id"
NEON_BRANCH_ID="replace-with-neon-branch-id"
NEON_ROLE_NAME="neondb_owner"
NEON_DATABASE_URL_TEMPLATE="postgresql://USER:PASSWORD@ep-example-pooler.c-7.us-east-1.aws.neon.tech/{database}?sslmode=require&channel_binding=require"
NEON_DIRECT_URL_TEMPLATE="postgresql://USER:PASSWORD@ep-example.c-7.us-east-1.aws.neon.tech/{database}?sslmode=require"

# Platform super admin panel (/super-admin)
SUPER_ADMIN_EMAIL=owner@smartshala.local
SUPER_ADMIN_PASSWORD_HASH="$2a$10$replace_with_bcrypt_hash"

# JWT secrets must be long random values in production.
JWT_ACCESS_SECRET="replace-with-a-long-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-refresh-secret"
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# DANGER: Never set to true in production - wipes all school data
DEMO_RESET_ENABLED=false

# Prisma logging: error,warn,info,query
PRISMA_LOG_LEVEL=error,warn
# Render deploy migration lock workaround. `npm run render:start` sets this too.
PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1

# WhatsApp Cloud API placeholders
WHATSAPP_ACCESS_TOKEN="replace-with-whatsapp-token"
WHATSAPP_PHONE_NUMBER_ID="replace-with-phone-number-id"
WHATSAPP_VERIFY_TOKEN="replace-with-verify-token"

# Queue-ready for notification jobs
REDIS_URL=redis://localhost:6379
