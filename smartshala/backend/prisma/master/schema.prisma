generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@smartshala/master-client"
}

datasource db {
  provider = "postgresql"
  url      = env("MASTER_DATABASE_URL")
}

model School {
  id               String        @id @default(uuid()) @db.Uuid
  schoolId         String        @unique @db.VarChar(8)
  schoolName       String
  ownerName        String
  email            String
  phone            String
  address          String
  numberOfStudents Int
  numberOfStaff    Int
  planType         PlanType
  paymentStatus    PaymentStatus @default(PENDING)
  amountPaid       Decimal       @default(0) @db.Decimal(12, 2)
  couponCode       String?
  isTrial          Boolean       @default(false)
  trialEndsAt      DateTime?
  isActive         Boolean       @default(true)
  deletionStatus   TenantDeletionStatus @default(NONE)
  deletionRequestedAt DateTime?
  deletionScheduledAt DateTime?
  deletionCancelledAt DateTime?
  deletionExecutedAt DateTime?
  deletionRequestedBy String?
  dbName           String        @unique
  dbUrl            String
  directDbUrl      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([schoolId, isActive])
  @@index([deletionStatus, deletionScheduledAt])
  @@index([email])
  @@map("schools")
}

model Coupon {
  id            String       @id @default(uuid()) @db.Uuid
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(12, 2)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  @@index([code, isActive])
  @@map("coupons")
}

model OnboardingLog {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.VarChar(8)
  status    String
  message   String
  createdAt DateTime @default(now())
  @@index([schoolId, createdAt])
  @@map("onboarding_logs")
}

enum PlanType {
  TRIAL
  STANDARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  TRIAL
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TenantDeletionStatus {
  NONE
  PENDING
  CANCELLED
  DELETED
  FAILED
}
