generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                       String                    @id @default(uuid()) @db.Uuid
  name                     String
  code                     String                    @unique
  city                     String?
  state                    String?
  phone                    String?
  gstin                    String?
  udiseNumber              String?
  affiliationBoard         String?
  logoUrl                  String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  attendanceSessions       AttendanceSession[]
  behaviourRecords         BehaviourRecord[]
  classes                  Class[]
  communicationLogs        CommunicationLog[]
  examResults              ExamResult[]
  exams                    Exam[]
  feeStructures            FeeStructure[]
  feeAdjustments           FeeAdjustment[]
  homeworkAssignments      HomeworkAssignment[]
  homeworkRecords          HomeworkRecord[]
  homeworkSubmissions      HomeworkSubmission[]
  notifications            Notification[]
  payments                 Payment[]
  receipts                 Receipt[]
  studentDocuments         StudentDocument[]
  feeAssignments           StudentFeeAssignment[]
  auditLogs                AuditLog[]
  students                 Student[]
  subjects                 Subject[]
  teacherPeriodAssignments TeacherPeriodAssignment[]
  users                    User[]

  @@map("schools")
}

model User {
  id                       String                    @id @default(uuid()) @db.Uuid
  schoolId                 String                    @db.Uuid
  fullName                 String
  email                    String?                   @unique
  phone                    String
  passwordHash             String
  role                     UserRole
  status                   UserStatus                @default(ACTIVE)
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  attendanceSessions       AttendanceSession[]       @relation("MarkedBy")
  assignedHomework         HomeworkAssignment[]       @relation("HomeworkAssignedBy")
  behaviourRecords         BehaviourRecord[]         @relation("BehaviourCreatedBy")
  classTeacherFor          Class[]                   @relation("ClassTeacher")
  paymentsRecorded         Payment[]                 @relation("PaymentRecordedBy")
  feeAdjustmentsRecorded   FeeAdjustment[]           @relation("FeeAdjustmentRecordedBy")
  refreshTokens            RefreshToken[]
  auditLogs                AuditLog[]                 @relation("AuditActor")
  uploadedStudentDocuments StudentDocument[]         @relation("StudentDocumentUploadedBy")
  teachingSubjects         Subject[]                 @relation("SubjectTeacher")
  periodAssignments        TeacherPeriodAssignment[] @relation("TeacherPeriodAssignmentTeacher")
  school                   School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, email])
  @@unique([schoolId, phone])
  @@index([schoolId, role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Class {
  id                       String                    @id @default(uuid()) @db.Uuid
  schoolId                 String                    @db.Uuid
  name                     String
  section                  String
  academicYear             String
  classTeacherId           String?                   @db.Uuid
  maximumStrength          Int?
  stream                   String?
  mediumOfInstruction      String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  attendanceSessions       AttendanceSession[]
  classTeacher             User?                     @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  school                   School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  exams                    Exam[]
  feeStructures            FeeStructure[]
  homeworkAssignments      HomeworkAssignment[]
  students                 Student[]
  subjects                 Subject[]
  teacherPeriodAssignments TeacherPeriodAssignment[]

  @@unique([schoolId, name, section, academicYear])
  @@index([schoolId, classTeacherId])
  @@map("classes")
}

model Student {
  id                  String                 @id @default(uuid()) @db.Uuid
  schoolId            String                 @db.Uuid
  classId             String                 @db.Uuid
  fullName            String
  admissionNumber     String
  rollNumber          Int?
  dateOfBirth         DateTime?
  gender              Gender?
  parentName          String
  parentPhone         String
  alternatePhone      String?
  fatherName          String?
  fatherPhone         String?
  fatherOccupation    String?
  motherName          String?
  motherPhone         String?
  motherOccupation    String?
  guardianName        String?
  guardianPhone       String?
  guardianOccupation  String?
  address             String?
  joiningDate         DateTime               @default(now())
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  attendanceRecords   AttendanceRecord[]
  behaviourRecords    BehaviourRecord[]
  communicationLogs   CommunicationLog[]
  examResults         ExamResult[]
  homeworkRecords     HomeworkRecord[]
  homeworkSubmissions HomeworkSubmission[]
  notifications       Notification[]
  payments            Payment[]
  feeAdjustments      FeeAdjustment[]
  documents           StudentDocument[]
  feeAssignments      StudentFeeAssignment[]
  class               Class                  @relation(fields: [classId], references: [id])
  school              School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, classId])
  @@index([schoolId, isActive])
  @@index([schoolId, parentPhone])
  @@index([schoolId, alternatePhone])
  @@map("students")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @db.Uuid
  actorId    String?  @db.Uuid
  entityType String
  entityId   String   @db.Uuid
  action     String
  summary    String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, entityType, entityId, createdAt])
  @@index([schoolId, actorId, createdAt])
  @@map("audit_logs")
}

model CommunicationLog {
  id          String                    @id @default(uuid()) @db.Uuid
  schoolId    String                    @db.Uuid
  studentId   String                    @db.Uuid
  type        CommunicationType
  channel     CommunicationChannel
  summary     String
  status      CommunicationStatus
  timestamp   DateTime                  @default(now())
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  messageType CommunicationMessageType?
  school      School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, timestamp])
  @@index([schoolId, type, channel])
  @@map("communication_logs")
}

model BehaviourRecord {
  id           String            @id @default(uuid()) @db.Uuid
  schoolId     String            @db.Uuid
  studentId    String            @db.Uuid
  createdById  String?           @db.Uuid
  type         BehaviourType
  title        String
  summary      String
  severity     BehaviourSeverity @default(LOW)
  occurredAt   DateTime          @default(now())
  isRestricted Boolean           @default(false)
  actionTaken  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdBy    User?             @relation("BehaviourCreatedBy", fields: [createdById], references: [id])
  school       School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, occurredAt])
  @@index([schoolId, type])
  @@index([schoolId, type, severity, occurredAt])
  @@map("behaviour_records")
}

model StudentDocument {
  id           String              @id @default(uuid()) @db.Uuid
  schoolId     String              @db.Uuid
  studentId    String              @db.Uuid
  uploadedById String              @db.Uuid
  type         StudentDocumentType
  name         String
  originalName String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  uploadedAt   DateTime            @default(now())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedBy   User                @relation("StudentDocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([schoolId, studentId, uploadedAt])
  @@index([schoolId, type])
  @@map("student_documents")
}

model Subject {
  id                       String                    @id @default(uuid()) @db.Uuid
  schoolId                 String                    @db.Uuid
  classId                  String?                   @db.Uuid
  name                     String
  code                     String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  teacherId                String?                   @db.Uuid
  examResults              ExamResult[]
  exams                    Exam[]                    @relation("ExamSubject")
  homeworkAssignments      HomeworkAssignment[]
  homeworkRecords          HomeworkRecord[]
  class                    Class?                    @relation(fields: [classId], references: [id])
  school                   School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher                  User?                     @relation("SubjectTeacher", fields: [teacherId], references: [id])
  teacherPeriodAssignments TeacherPeriodAssignment[]

  @@unique([schoolId, classId, name])
  @@index([schoolId, classId])
  @@index([schoolId, teacherId])
  @@map("subjects")
}

model TeacherPeriodAssignment {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @db.Uuid
  teacherId    String   @db.Uuid
  periodNumber Int
  classId      String?  @db.Uuid
  subjectId    String?  @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  class        Class?   @relation(fields: [classId], references: [id])
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject      Subject? @relation(fields: [subjectId], references: [id])
  teacher      User     @relation("TeacherPeriodAssignmentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, periodNumber])
  @@index([schoolId, teacherId])
  @@index([schoolId, classId])
  @@index([schoolId, subjectId])
  @@map("teacher_period_assignments")
}

model Exam {
  id         String       @id @default(uuid()) @db.Uuid
  schoolId   String       @db.Uuid
  classId    String?      @db.Uuid
  name       String
  term       ExamTerm     @default(UNIT_TEST)
  examDate   DateTime     @default(now())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  subjectId  String?      @db.Uuid
  maxMarks   Decimal?     @db.Decimal(6, 2)
  results    ExamResult[]
  class      Class?       @relation(fields: [classId], references: [id])
  school     School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectRef Subject?     @relation("ExamSubject", fields: [subjectId], references: [id])

  @@index([schoolId, classId, examDate])
  @@index([schoolId, subjectId])
  @@index([schoolId, term])
  @@map("exams")
}

model ExamResult {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @db.Uuid
  studentId      String   @db.Uuid
  subject        String?
  assessmentName String
  marksObtained  Decimal  @db.Decimal(6, 2)
  maxMarks       Decimal  @db.Decimal(6, 2)
  examDate       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  examId         String?  @db.Uuid
  subjectId      String?  @db.Uuid
  percentage     Decimal? @db.Decimal(5, 2)
  grade          String?
  exam           Exam?    @relation(fields: [examId], references: [id])
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectRef     Subject? @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examId])
  @@index([schoolId, studentId, examDate])
  @@index([schoolId, examId, subjectId])
  @@map("exam_results")
}

model HomeworkRecord {
  id                   String    @id @default(uuid()) @db.Uuid
  schoolId             String    @db.Uuid
  studentId            String    @db.Uuid
  title                String
  subject              String?
  completionPercentage Decimal   @db.Decimal(5, 2)
  dueDate              DateTime?
  submittedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  subjectId            String?   @db.Uuid
  school               School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student              Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectRef           Subject?  @relation(fields: [subjectId], references: [id])

  @@index([schoolId, studentId, dueDate])
  @@index([schoolId, subjectId])
  @@map("homework_records")
}

model HomeworkAssignment {
  id           String               @id @default(uuid()) @db.Uuid
  schoolId     String               @db.Uuid
  classId      String               @db.Uuid
  subjectId    String?              @db.Uuid
  subject      String?
  title        String
  assignedDate DateTime             @default(now())
  dueDate      DateTime
  maxMarks     Decimal?             @db.Decimal(6, 2)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  description  String?
  assignedById String?               @db.Uuid
  assignedBy   User?                 @relation("HomeworkAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  class        Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectRef   Subject?             @relation(fields: [subjectId], references: [id])
  submissions  HomeworkSubmission[]

  @@index([schoolId, classId, dueDate])
  @@index([schoolId, assignedById])
  @@index([schoolId, subjectId])
  @@map("homework_assignments")
}

model HomeworkSubmission {
  id           String                   @id @default(uuid()) @db.Uuid
  schoolId     String                   @db.Uuid
  assignmentId String                   @db.Uuid
  studentId    String                   @db.Uuid
  status       HomeworkSubmissionStatus
  marks        Decimal?                 @db.Decimal(6, 2)
  teacherNote  String?
  submittedAt  DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  assignment   HomeworkAssignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  school       School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([schoolId, studentId, status])
  @@index([schoolId, assignmentId])
  @@map("homework_submissions")
}

model AttendanceSession {
  id          String             @id @default(uuid()) @db.Uuid
  schoolId    String             @db.Uuid
  classId     String             @db.Uuid
  date        DateTime
  markedById  String             @db.Uuid
  submittedAt DateTime           @default(now())
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  records     AttendanceRecord[]
  class       Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedBy    User               @relation("MarkedBy", fields: [markedById], references: [id])
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, date])
  @@index([schoolId, date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String            @id @default(uuid()) @db.Uuid
  schoolId  String            @db.Uuid
  sessionId String            @db.Uuid
  studentId String            @db.Uuid
  status    AttendanceStatus
  attendanceValue Decimal     @default(1) @db.Decimal(3, 2)
  remarks   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([schoolId, studentId])
  @@index([schoolId, status])
  @@map("attendance_records")
}

model FeeStructure {
  id           String                 @id @default(uuid()) @db.Uuid
  schoolId     String                 @db.Uuid
  classId      String?                @db.Uuid
  name         String
  academicYear String
  frequency    FeeFrequency
  totalAmount  Decimal                @db.Decimal(12, 2)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  installments FeeInstallment[]
  class        Class?                 @relation(fields: [classId], references: [id])
  school       School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments  StudentFeeAssignment[]

  @@index([schoolId, academicYear])
  @@index([schoolId, classId])
  @@map("fee_structures")
}

model FeeInstallment {
  id             String       @id @default(uuid()) @db.Uuid
  feeStructureId String       @db.Uuid
  name           String
  dueDate        DateTime
  amount         Decimal      @db.Decimal(12, 2)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([feeStructureId, dueDate])
  @@map("fee_installments")
}

model StudentFeeAssignment {
  id             String            @id @default(uuid()) @db.Uuid
  schoolId       String            @db.Uuid
  studentId      String            @db.Uuid
  feeStructureId String            @db.Uuid
  totalAmount    Decimal           @db.Decimal(12, 2)
  paidAmount     Decimal           @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal           @db.Decimal(12, 2)
  status         InstallmentStatus @default(PENDING)
  assignedAt     DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  payments       Payment[]
  adjustments    FeeAdjustment[]
  feeStructure   FeeStructure      @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, feeStructureId])
  @@index([schoolId, status])
  @@index([schoolId, studentId, status])
  @@map("student_fee_assignments")
}

model Payment {
  id            String               @id @default(uuid()) @db.Uuid
  schoolId      String               @db.Uuid
  studentId     String               @db.Uuid
  assignmentId  String               @db.Uuid
  installmentId String?              @db.Uuid
  recordedById  String               @db.Uuid
  amount        Decimal              @db.Decimal(12, 2)
  mode          PaymentMode
  upiTransactionId     String?
  chequeNumber         String?
  ddNumber             String?
  gatewayTransactionId String?
  bankReference        String?
  paidAt        DateTime             @default(now())
  notes         String?
  createdAt     DateTime             @default(now())
  assignment    StudentFeeAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  installment   FeeInstallment?      @relation(fields: [installmentId], references: [id])
  recordedBy    User                 @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  school        School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  receipt       Receipt?

  @@index([schoolId, paidAt])
  @@index([schoolId, studentId, paidAt])
  @@map("payments")
}

model FeeAdjustment {
  id            String               @id @default(uuid()) @db.Uuid
  schoolId      String               @db.Uuid
  studentId     String               @db.Uuid
  assignmentId  String               @db.Uuid
  recordedById  String               @db.Uuid
  type          FeeAdjustmentType
  amount        Decimal              @db.Decimal(12, 2)
  reason        String
  createdAt     DateTime             @default(now())
  assignment    StudentFeeAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  recordedBy    User                 @relation("FeeAdjustmentRecordedBy", fields: [recordedById], references: [id])
  school        School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId, createdAt])
  @@index([schoolId, assignmentId])
  @@map("fee_adjustments")
}

model Receipt {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  paymentId String   @unique @db.Uuid
  receiptNo String
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, receiptNo])
  @@map("receipts")
}

model Notification {
  id                String             @id @default(uuid()) @db.Uuid
  schoolId          String             @db.Uuid
  studentId         String?            @db.Uuid
  kind              NotificationKind
  recipientPhone    String
  message           String
  status            NotificationStatus @default(QUEUED)
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student?           @relation(fields: [studentId], references: [id])

  @@index([schoolId, status, createdAt])
  @@index([schoolId, createdAt])
  @@map("notifications")
}

enum UserRole {
  PRINCIPAL
  ADMIN
  TEACHER
  ACCOUNTANT
  PARENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum FeeFrequency {
  ANNUAL
  QUARTERLY
  MONTHLY
  CUSTOM
  BIANNUAL
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  DD
  ONLINE_GATEWAY
  OTHER
}

enum FeeAdjustmentType {
  CONCESSION
  DISCOUNT
}

enum ExamTerm {
  UNIT_TEST
  MID_TERM
  FINAL
  TERM_1
  TERM_2
}

enum NotificationKind {
  ABSENCE
  LOW_ATTENDANCE
  FEE_REMINDER
  OVERDUE_FEE
  PAYMENT_RECEIPT
  MONTHLY_REPORT
  SCHOOL_ALERT
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum HomeworkSubmissionStatus {
  ON_TIME
  LATE
  MISSING
  NOT_SUBMITTED
}

enum CommunicationType {
  WHATSAPP
  MANUAL_NOTE
  CALL
}

enum CommunicationChannel {
  WHATSAPP
  PHONE
  IN_PERSON
  INTERNAL
}

enum CommunicationStatus {
  QUEUED
  SENT
  FAILED
  COMPLETED
  MISSED
  NOTE
}

enum CommunicationMessageType {
  ATTENDANCE_ALERT
  ABSENCE_NOTIFICATION
  FEE_REMINDER
  EXAM_ANNOUNCEMENT
  PTM_INVITE
  HOLIDAY_NOTICE
  GENERIC_NOTICE
  BIRTHDAY_WISH
  HOMEWORK_REMINDER
  CUSTOM
}

enum BehaviourType {
  INCIDENT
  ACHIEVEMENT
  COUNSELLOR_NOTE
}

enum BehaviourSeverity {
  LOW
  MEDIUM
  HIGH
  POSITIVE
  NOTE
}

enum StudentDocumentType {
  CERTIFICATE
  MEDICAL
  PARENT_ID
  AGREEMENT
  AADHAAR
  APAAR
  BIRTH_CERTIFICATE
  CASTE_CERTIFICATE
  TRANSFER_CERTIFICATE
  BONAFIDE
  REPORT_CARD
  PHOTO
}
