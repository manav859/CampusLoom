generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

enum PageStatus {
  draft
  published
}

enum NoticeType {
  general
  exam
  holiday
  urgent
}

model Page {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  slug           String     @unique
  content        Json
  status         PageStatus @default(draft)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Notice {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  type        NoticeType @default(general)
  publishDate DateTime
  expiryDate  DateTime?
  isActive    Boolean    @default(true)
  createdBy   String     @db.ObjectId
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isActive, publishDate, expiryDate])
  @@index([type, publishDate])
}
