# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────
# MongoDB connection string (local or Atlas)
DATABASE_URL=mongodb://localhost:27017/schoolos

# ─── Auth ────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
